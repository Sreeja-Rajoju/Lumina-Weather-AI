# OpenWeather API Key - Get one at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Google GenAI API Keys (Gemini/Gemma) - Get at https://aistudio.google.com/
# You can provide multiple keys separated by commas for automatic fallback
GEMINI_API_KEYS=your_first_key_here,your_second_fallback_key_here

# Optional: Port for the Flask application
PORT=5000
